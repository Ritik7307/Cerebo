# --- DATABASE (Supabase / Postgres) ---
# Your Postgres connection pooler URL (starts with postgresql:// and ends with ?pgbouncer=true)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Your direct Postgres connection URL (starts with postgresql:// and ends with :5432/postgres)
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- AUTH (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# --- AI & APIs ---
GROQ_API_KEY="gsk_..."
YOUTUBE_API_KEY="AIza..."

# --- SUPABASE (Optional - if using Supabase client directly) ---
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
