{
  "manifest_version": 3,
  "name": "Cerebo Volume Booster",
  "version": "1.0",
  "description": "Boost audio volume up to 600% on any tab.",
  "permissions": ["storage", "webNavigation"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
